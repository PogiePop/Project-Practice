<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.audit.mapper.sys.SysRoleMapper">

    <!-- ==================== 结果映射 ==================== -->
    <resultMap id="roleMap" type="com.audit.entity.sys.SysRole">
        <id property="roleId" column="role_id"/>
        <result property="roleName" column="role_name"/>
        <result property="roleKey" column="role_key"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- ==================== 角色CRUD ==================== -->
    <select id="findAll" resultMap="roleMap">
        SELECT * FROM sys_role
        <where>
            <if test="keyword != null and keyword != ''">
                role_name LIKE CONCAT('%',#{keyword},'%') OR role_key LIKE CONCAT('%',#{keyword},'%')
            </if>
        </where>
        ORDER BY create_time
    </select>

    <select id="findById" resultMap="roleMap">
        SELECT * FROM sys_role WHERE role_id = #{roleId}
    </select>

    <select id="findByKey" resultMap="roleMap">
        SELECT * FROM sys_role WHERE role_key = #{roleKey}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="roleId">
        INSERT INTO sys_role (role_name, role_key, status, remark)
        VALUES (#{roleName}, #{roleKey}, #{status}, #{remark})
    </insert>

    <update id="update">
        UPDATE sys_role
        <set>
            <if test="roleName != null">role_name = #{roleName},</if>
            <if test="roleKey != null">role_key = #{roleKey},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        WHERE role_id = #{roleId}
    </update>

    <delete id="delete">
        DELETE FROM sys_role WHERE role_id = #{roleId}
    </delete>

    <!-- ==================== 角色-权限关联 ==================== -->
    <select id="findPermIdsByRoleId" resultType="long">
        SELECT perm_id FROM sys_role_permission WHERE role_id = #{roleId}
    </select>

    <delete id="deleteRolePerms">
        DELETE FROM sys_role_permission WHERE role_id = #{roleId}
    </delete>

    <insert id="insertRolePerms">
        INSERT INTO sys_role_permission (role_id, perm_id) VALUES
        <foreach collection="permIds" item="permId" separator=",">
            (#{roleId}, #{permId})
        </foreach>
    </insert>

    <!-- ==================== 用户-角色 ==================== -->
    <select id="findRoleKeysByUserId" resultType="string">
        SELECT r.role_key FROM sys_user_role ur
        JOIN sys_role r ON r.role_id = ur.role_id
        WHERE ur.user_id = #{userId} AND r.status = 1
    </select>

</mapper>
