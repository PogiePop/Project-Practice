<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.audit.mapper.sys.SysPermissionMapper">

    <!-- ==================== 结果映射 ==================== -->
    <resultMap id="permMap" type="com.audit.entity.sys.SysPermission">
        <id property="permId" column="perm_id"/>
        <result property="parentId" column="parent_id"/>
        <result property="permName" column="perm_name"/>
        <result property="perms" column="perms"/>
        <result property="type" column="type"/>
        <result property="path" column="path"/>
        <result property="icon" column="icon"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!-- ==================== 查询 ==================== -->
    <select id="findAll" resultMap="permMap">
        SELECT * FROM sys_permission WHERE status = 1 ORDER BY sort_order, perm_id
    </select>

    <select id="findByType" resultMap="permMap">
        SELECT * FROM sys_permission WHERE type = #{type} AND status = 1 ORDER BY sort_order, perm_id
    </select>

    <!-- 根据角色key列表查询所有权限标识符 -->
    <select id="findPermsByRoleKeys" resultType="string">
        SELECT DISTINCT p.perms
        FROM sys_permission p
        JOIN sys_role_permission rp ON rp.perm_id = p.perm_id
        JOIN sys_role r ON r.role_id = rp.role_id
        WHERE r.role_key IN
        <foreach collection="roleKeys" item="key" open="(" separator="," close=")">
            #{key}
        </foreach>
        AND p.perms IS NOT NULL AND p.status = 1 AND r.status = 1
    </select>

    <!-- 根据角色key列表查询菜单权限（type=1 菜单） -->
    <select id="findMenuByRoleKeys" resultMap="permMap">
        SELECT DISTINCT p.*
        FROM sys_permission p
        JOIN sys_role_permission rp ON rp.perm_id = p.perm_id
        JOIN sys_role r ON r.role_id = rp.role_id
        WHERE r.role_key IN
        <foreach collection="roleKeys" item="key" open="(" separator="," close=")">
            #{key}
        </foreach>
        AND p.type IN (0, 1) AND p.status = 1 AND r.status = 1
        ORDER BY p.sort_order, p.perm_id
    </select>

</mapper>
